{
  "base_url": "http://your-backend.example.com",
  "dotai_base_url": "http://your-dotai-backend.example.com",
  "proxy": {
    "http": "http://127.0.0.1:7890",
    "https": "http://127.0.0.1:7890",
    "no_proxy": ""
  },
  "auth": {
    "token": "Bearer replace_with_your_token",
    "uid": "replace_with_uid",
    "email": "replace_with_email@example.com"
  },
  "llm_eval": {
    "enabled": true,
    "base_url": "https://api.ikuncode.cc/v1/responses",
    "model": "gpt-5.3-codex",
    "api_key": "replace_with_eval_api_key",
    "timeout_sec": 60
  },
  "user_simulator": {
    "enabled": true,
    "mode": "provider_context",
    "base_url": "https://api.ikuncode.cc/v1/responses",
    "model": "gpt-5.3-codex",
    "api_key": "replace_with_user_simulator_api_key",
    "timeout_sec": 60,
    "max_turns": 20,
    "capability_mode": "alternating",
    "user_temperature": 0.9,
    "role_temperature": 1.0,
    "first_user_message": "请你把当前记忆文件重置为系统初始模板",
    "system_prompt_file": "user_simulator_system.prompt",
    "scenario_prompt_file": "user_simulator_scenario.prompt",
    "role_system_prompt_file": "user_simulator_role_system.prompt",
    "role_user_prompt_file": "user_simulator_role_user.prompt"
  }
}
