{
  "base_url": "http://your-backend.example.com",
  "dotai_base_url": "http://your-dotai-backend.example.com",
  "proxy": {
    "http": "http://127.0.0.1:7890",
    "https": "http://127.0.0.1:7890",
    "no_proxy": ""
  },
  "auth": {
    "token": "Bearer replace_with_your_token",
    "uid": "replace_with_uid",
    "email": "replace_with_email@example.com"
  },
  "llm_eval": {
    "enabled": true,
    "base_url": "https://api.ikuncode.cc/v1/responses",
    "model": "gpt-5.3-codex",
    "api_key": "replace_with_eval_api_key",
    "timeout_sec": 60
  },
  "user_simulator": {
    "enabled": true,
    "mode": "provider_context",
    "target_name": "advoo",
    "base_url": "https://api.ikuncode.cc/v1/responses",
    "model": "gpt-5.3-codex",
    "api_key": "replace_with_user_simulator_api_key",
    "timeout_sec": 60,
    "max_turns": 20,
    "capability_mode": "alternating",
    "user_temperature": 0.9,
    "role_temperature": 1.0,
    "first_user_message": "请你把当前记忆文件重置为系统初始模板",
    "system_prompt_file": "framework/simulator/system/user_simulator_system.prompt",
    "role_system_prompt_file": "framework/simulator/role_generation/role_system.prompt",
    "role_user_prompt_file": "framework/simulator/role_generation/role_user.prompt"
  },
  "probe_eval": {
    "enabled": true,
    "dataset_path": "datasets/probes/clinic_memory_v1.json",
    "fail_on_error": true,
    "max_fail_details": 20,
    "llm_judge": {
      "enabled": false,
      "base_url": "https://api.ikuncode.cc/v1/responses",
      "model": "gpt-5.3-codex",
      "api_key": "replace_with_probe_judge_api_key",
      "timeout_sec": 45,
      "repeats": 3,
      "max_retries": 2,
      "fail_open": false,
      "system_prompt_file": "framework/evaluator/probe/probe_judge_system.prompt",
      "user_prompt_file": "framework/evaluator/probe/probe_judge_user.prompt"
    },
    "score_merge": {
      "deterministic_weight": 0.65,
      "llm_weight": 0.35
    }
  }
}
